<Window x:Class="InstallReceipt.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Install Receipt" Height="760" Width="1180" MinHeight="640" MinWidth="960"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F6F7F8"/>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D8DEE4"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#1F2328"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#57606A"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="#D0D7DE"/>
        <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ListHeaderBackgroundBrush" Color="#F6F8FA"/>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>
        <Style TargetType="ListView">
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{DynamicResource ListHeaderBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>
        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Install Receipt" FontSize="28" FontWeight="SemiBold"/>
                <TextBlock Text="インストール前後のPC状態を比較し、増えたものをローカルでレシート化します。"
                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
                <CheckBox x:Name="DarkModeToggle" Content="ダークモード" HorizontalAlignment="Right"
                          Margin="0,0,0,12" Checked="DarkModeToggle_Changed" Unchecked="DarkModeToggle_Changed"/>
                <TextBlock Text="アプリ名メモ" Style="{StaticResource MetricLabel}"/>
                <TextBox x:Name="AppHintTextBox" Margin="0,4,0,0" Padding="8"
                         ToolTip="レシート名に使う任意メモ。アンインストール登録が検出された場合はそちらを優先します。"/>
            </StackPanel>
        </Grid>

        <WrapPanel Grid.Row="1" Margin="0,0,0,8">
            <Button x:Name="CaptureBeforeButton" Content="事前スナップショット" Click="CaptureBefore_Click"/>
            <Button x:Name="CaptureAfterButton" Content="事後スナップショット + 差分" Click="CaptureAfter_Click"/>
            <Button x:Name="LoadBeforeButton" Content="事前を読み込み" Click="LoadBefore_Click"/>
            <Button x:Name="LoadAfterButton" Content="事後を読み込み + 差分" Click="LoadAfter_Click"/>
            <Button x:Name="ExportJsonButton" Content="JSON保存" Click="ExportJson_Click" IsEnabled="False"/>
            <Button x:Name="ExportHtmlButton" Content="HTML保存" Click="ExportHtml_Click" IsEnabled="False"/>
            <Button x:Name="ExportMarkdownButton" Content="Markdown保存" Click="ExportMarkdown_Click" IsEnabled="False"/>
        </WrapPanel>

        <Grid Grid.Row="2" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusTextBlock" Text="事前スナップショットを取得してから、通常どおりアプリをインストールしてください。"
                       Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
            <ProgressBar x:Name="BusyProgressBar" Grid.Column="1" Height="8" IsIndeterminate="True" Visibility="Collapsed"/>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="概要" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <UniformGrid Columns="2" Rows="6">
                            <StackPanel Margin="0,0,10,12">
                                <TextBlock Text="注意度" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="AttentionTextBlock" Text="-" Style="{StaticResource MetricValue}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="追加項目" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="AddedFilesTextBlock" Text="-" Style="{StaticResource MetricValue}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,12">
                                <TextBlock Text="自動起動" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="StartupTextBlock" Text="-" Style="{StaticResource MetricValue}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="サービス" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="ServicesTextBlock" Text="-" Style="{StaticResource MetricValue}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,12">
                                <TextBlock Text="タスク" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="TasksTextBlock" Text="-" Style="{StaticResource MetricValue}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="AppData" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="AppDataTextBlock" Text="-" Style="{StaticResource MetricValue}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,12">
                                <TextBlock Text="アプリ登録" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="InstalledAppsTextBlock" Text="-" Style="{StaticResource MetricValue}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="関連付け" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="AssociationsTextBlock" Text="-" Style="{StaticResource MetricValue}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,12">
                                <TextBlock Text="右クリック" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="ContextMenuTextBlock" Text="-" Style="{StaticResource MetricValue}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="サイズ" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="SizeTextBlock" Text="-" Style="{StaticResource MetricValue}"/>
                            </StackPanel>
                        </UniformGrid>

                        <TextBlock Text="追加されなかったもの" FontWeight="SemiBold" Margin="0,12,0,6"/>
                        <ItemsControl x:Name="NotDetectedItemsControl"/>

                        <TextBlock Text="スキャン警告" FontWeight="SemiBold" Margin="0,16,0,6"/>
                        <TextBox x:Name="WarningsTextBox" IsReadOnly="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" MinHeight="90"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="レシート項目" FontSize="18" FontWeight="SemiBold" Margin="4,0,0,12"/>
                    <ListView x:Name="ReceiptItemsListView" Grid.Row="1">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="種類" DisplayMemberBinding="{Binding Type}" Width="130"/>
                                <GridViewColumn Header="名前" DisplayMemberBinding="{Binding Name}" Width="220"/>
                                <GridViewColumn Header="説明" DisplayMemberBinding="{Binding Description}" Width="300"/>
                                <GridViewColumn Header="場所" DisplayMemberBinding="{Binding Path}" Width="360"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="4" Margin="0,12,0,0" Foreground="{DynamicResource SecondaryTextBrush}"
                   Text="このMVPはAI判定・自動削除・クラウド送信を行いません。ファイル本文は読み取らず、代表的な場所のメタ情報だけを比較します。"/>
    </Grid>
</Window>
